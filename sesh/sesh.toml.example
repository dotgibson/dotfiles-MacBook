# core/sesh/sesh.toml.example  → bootstrap copies to ~/.config/sesh/sesh.toml
# ──────────────────────────────────────────────────────────────────────────────
# sesh (joshmedeski/sesh) config. PORTABLE defaults only — anything engagement-
# flavoured (per-client window layouts, ~/engagements/* startup commands) belongs
# in dotfiles-Kali's own sesh.toml, NOT here. sesh merges multiple configs via
# [[import]] if you want to layer the Kali one on top.
#
# Docs: https://github.com/joshmedeski/sesh
# ──────────────────────────────────────────────────────────────────────────────

[default_session]
# What every new session runs unless a [[session]] below overrides it. Drops you
# into a file picker so a fresh session is immediately useful.
startup_command = "nvim ."
preview_command = "eza --all --icons --tree --level=1 --color=always {}"

# Sort: your saved configs first, then live tmux sessions, then zoxide dirs.
[[sort_order]]
# (left as default order: config, tmux, zoxide)

# ── Example session configs (uncomment / adapt) ───────────────────────────────
# [[session]]
# name = "dotfiles"
# path = "~/.config"
# startup_command = "nvim ."
#
# [[session]]
# name = "notes"
# path = "~/Notes"
# startup_command = "nvim ."

# ── Wildcard configs — apply settings to any matching path ────────────────────
# [[window]]
# name = "editor"
# startup_script = "nvim ."

# Layer the offensive config on top (only exists on Kali; missing = ignored):
# [[import]]
# path = "~/.config/sesh/sesh.offensive.toml"
