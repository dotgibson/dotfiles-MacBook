# dotfiles-MacBook/zsh/zshrc  →  ~/.config/zsh/.zshrc
# ──────────────────────────────────────────────────────────────────────────────
# Interactive shell. Sources the Core modules (+ the macOS os layer + any local
# overrides) in the ONE correct order (matches the loop below and README):
#   tools → ui -> options → history → aliases → git → functions → fzf → bindings
#         → plugins → op → maint → update → os → local
#
# WHAT CHANGED (2026 refresh integration):
#   • options.zsh + history.zsh are NEW Core modules that now own setopts, the
#     completion system (compinit), and history config. They replace the inline
#     blocks that used to live in THIS file — that duplication was exactly the
#     drift the Core layer exists to kill, so the inline copies are gone.
#   • update.zsh (the `up` command + the once/day "updates available" nudge) and
#     maint.zsh (`maint-install` etc.) are sourced too — previously they were
#     symlinked into ~/.config/zsh but never loaded, so `up`/`maint-install`
#     didn't exist.
#
# Order is load-bearing: tools inits atuin (registers its widget) and fzf defines
# its zle widgets BEFORE plugins.zsh loads zsh-vi-mode, whose init fires the
# keybinding hook in bindings.zsh. options.zsh runs compinit BEFORE plugins.zsh
# (fzf-tab + carapace need it). update.zsh sits late so its nudge prints just
# above the prompt (incl. inside each new tmux pane).
#
# NOTE on history location: history.zsh sets HISTFILE to $ZDOTDIR/.zsh_history
# (was $XDG_STATE_HOME/zsh/history here). atuin holds your real searchable
# history regardless; if you want the old flat-file path, set HISTFILE in
# ~/.config/zsh/local.zsh (sourced last, so it wins).
# ──────────────────────────────────────────────────────────────────────────────

# ── XDG fallbacks ─────────────────────────────────────────────────────────────
# .zshenv normally exports these before we get here. Guard anyway so nothing
# downstream collapses to a bare path if .zshenv hasn't run (e.g. .zshrc sourced
# standalone).
: "${XDG_STATE_HOME:=$HOME/.local/state}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"

# ── Core modules + macOS layer + local overrides, in order ───────────────────
# (history + completion/compinit + setopts are owned by history.zsh/options.zsh.)
#
# The byte-compile-then-source loop now lives in the VENDORED Core loader
# (core/zsh/loader.zsh → ~/.config/zsh/loader.zsh), so every OS repo declares the load
# order and sources ONE shared implementation instead of hand-rolling the same ~10 lines
# (B12). loader.zsh runs at THIS top-level scope — never wrapped in a function — so the
# setopts / aliases / compinit each module performs persist into the interactive shell.
# (It byte-compiles each module to a .zwc beside its symlink and sources the wordcode;
# self-healing on edit/pull; .zwc files stay in $ZSH_CFG, never the repo.)
ZSH_CFG="${ZDOTDIR:-$HOME/.config/zsh}"
_CORE_MODULES=(tools ui options history aliases git functions fzf bindings plugins op maint update os local)
# Prefer the installed runtime symlink ($ZSH_CFG/loader.zsh). FALLBACK to the vendored copy
# via this file's OWN resolved path, because a plain `git pull` updates this (symlinked)
# .zshrc to reference loader.zsh BEFORE the user re-runs `./bootstrap.sh --links-only` that
# creates the symlink — and without a fallback every interactive shell would then start with
# NO Core modules. (Before B12 the inline loop skipped missing modules one-by-one; the
# single vendored loader is all-or-nothing, so it needs this guard.)
if [[ -r "$ZSH_CFG/loader.zsh" ]]; then
  source "$ZSH_CFG/loader.zsh"
else
  _zshrc_self="${${(%):-%N}:A}" # resolved real path of THIS sourced file (<repo>/zsh/zshrc)
  if [[ -r "${_zshrc_self:h:h}/core/zsh/loader.zsh" ]]; then
    source "${_zshrc_self:h:h}/core/zsh/loader.zsh"
    print -u2 -- "zshrc: loader.zsh not linked yet — used the repo copy. Run ./bootstrap.sh --links-only to (re)link Core."
  else
    print -u2 -- "zshrc: loader.zsh not found — run ./bootstrap.sh --links-only (Core modules not loaded)."
  fi
  unset _zshrc_self
fi
unset _CORE_MODULES

# ── auto-start/attach tmux (runs AFTER local.zsh, so its opt-out knobs work) ──
# Placed here — not in the `os` module — because the loader above already sourced
# every module INCLUDING local.zsh, so DOTFILES_NO_AUTOTMUX / DOTFILES_TMUX_SESSION
# set there are now honored (the `os` module loads before `local` and couldn't read
# them). `exec` replaces this login shell so detaching exits the terminal cleanly;
# `new-session -A` attaches if the session exists, else creates it. Skips inside an
# existing tmux, VS Code's integrated terminal, and non-TTYs.
if command -v tmux >/dev/null 2>&1 \
  && [[ -z "$TMUX" && -t 1 && "$TERM_PROGRAM" != "vscode" && -z "${DOTFILES_NO_AUTOTMUX:-}" ]]; then
  exec tmux new-session -A -s "${DOTFILES_TMUX_SESSION:-main}"
fi
