# dotfiles-MacBook/zsh/zshrc  →  ~/.config/zsh/.zshrc
# ──────────────────────────────────────────────────────────────────────────────
# Interactive shell. Sources the Core modules (+ the macOS os layer + any local
# overrides). v4 replaced the hand-declared module-name list with NUMBERED fragments:
# every Core module is `NN-name.zsh` (00-tools … 60-update), the macOS layer lands as
# `80-os.zsh`, and host tweaks as `99-local.zsh` — all symlinked FLAT into $ZSH_CFG. The
# vendored loader globs them, sorts by the NN prefix, and sources each in order, so this
# file no longer lists module names — it just sources loader.zsh (below).
#
# Order is load-bearing and is encoded in the numbering: 00-tools inits atuin (registers
# its widget) and 35-fzf defines its zle widgets BEFORE 45-plugins loads zsh-vi-mode, whose
# init fires the keybinding hook in 40-bindings. 10-options runs compinit BEFORE 45-plugins
# (fzf-tab + carapace need it). 60-update sits late so its nudge prints just above the
# prompt (incl. inside each new tmux pane).
#
# NOTE on history location (v4): 15-history.zsh sets HISTFILE under $XDG_STATE_HOME/zsh/history
# — history is mutable STATE, not config, so it no longer lives in the symlinked $ZDOTDIR tree.
# atuin holds your real searchable history regardless; override HISTFILE in
# ~/.config/zsh/99-local.zsh (the loader sources it last, so it wins) for a different path.
# ──────────────────────────────────────────────────────────────────────────────

# ── XDG fallbacks ─────────────────────────────────────────────────────────────
# .zshenv normally exports these before we get here. Guard anyway so nothing
# downstream collapses to a bare path if .zshenv hasn't run (e.g. .zshrc sourced
# standalone).
: "${XDG_STATE_HOME:=$HOME/.local/state}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"

# ── Core fragments + macOS layer + local overrides, via the numbered loader ──
# (history + completion/compinit + setopts are owned by 15-history.zsh/10-options.zsh.)
#
# The glob-sort-byte-compile-then-source loop lives in the VENDORED Core loader
# (core/zsh/loader.zsh → ~/.config/zsh/loader.zsh): it globs $ZSH_CFG/NN-*.zsh, sorts by the
# NN prefix, and sources ONE shared implementation instead of this file hand-listing modules
# (v4). loader.zsh runs at THIS top-level scope — never wrapped in a function — so the
# setopts / aliases / compinit each fragment performs persist into the interactive shell.
# (It byte-compiles each fragment to a .zwc beside its symlink and sources the wordcode;
# self-healing on edit/pull; .zwc files stay in $ZSH_CFG, never the repo.)
ZSH_CFG="${ZDOTDIR:-$HOME/.config/zsh}"
# Prefer the installed runtime symlink ($ZSH_CFG/loader.zsh). FALLBACK to the vendored copy
# via this file's OWN resolved path, because a plain `git pull` updates this (symlinked)
# .zshrc to reference loader.zsh BEFORE the user re-runs `./bootstrap.sh --links-only` that
# creates the symlink — and without a fallback every interactive shell would then start with
# NO Core modules. (Before B12 the inline loop skipped missing modules one-by-one; the
# single vendored loader is all-or-nothing, so it needs this guard.)
if [[ -r "$ZSH_CFG/loader.zsh" ]]; then
  source "$ZSH_CFG/loader.zsh"
else
  _zshrc_self="${${(%):-%N}:A}" # resolved real path of THIS sourced file (<repo>/zsh/zshrc)
  if [[ -r "${_zshrc_self:h:h}/core/zsh/loader.zsh" ]]; then
    source "${_zshrc_self:h:h}/core/zsh/loader.zsh"
    print -u2 -- "zshrc: loader.zsh not linked yet — used the repo copy. Run ./bootstrap.sh --links-only to (re)link Core."
  else
    print -u2 -- "zshrc: loader.zsh not found — run ./bootstrap.sh --links-only (Core modules not loaded)."
  fi
  unset _zshrc_self
fi

# ── auto-start/attach tmux (runs AFTER local.zsh, so its opt-out knobs work) ──
# Placed here — not in the `os` module — because the loader above already sourced
# every module INCLUDING local.zsh, so DOTFILES_NO_AUTOTMUX / DOTFILES_TMUX_SESSION
# set there are now honored (the `os` module loads before `local` and couldn't read
# them). `exec` replaces the current shell so detaching exits the terminal cleanly.
# Skips inside an existing tmux, VS Code's integrated terminal, and non-TTYs (macOS
# terminals start login+interactive shells, so in practice this runs once per window).
#
# WHY THIS IS NOT just `new-session -A -s <name>`: core/tmux.conf enables
# tmux-continuum (`@continuum-restore 'on'`), which restores the last-saved
# environment when the tmux SERVER boots. If our command is the thing that boots the
# server, our session gets created ALONGSIDE whatever continuum restores under its own
# saved name — so you land in two sessions (e.g. a restored `main` next to the one we
# spawn). Renaming the target via DOTFILES_TMUX_SESSION can't fix that: the restored
# session keeps its OLD saved name, so `-A` still can't merge the two.
#
# The fix: boot the server FIRST (without committing to a session), let continuum's
# restore land, THEN reconcile into a single session with the name you want:
#   • exactly one differently-named session present (stale save) → rename it to the
#     wanted name, preserving its restored windows/panes
#   • then a single race-safe `new-session -A` attaches to the wanted session (running,
#     restored, or just renamed) or creates it if there's nothing to attach to
if command -v tmux >/dev/null 2>&1 \
  && [[ -z "$TMUX" && -t 1 && "$TERM_PROGRAM" != "vscode" && -z "${DOTFILES_NO_AUTOTMUX:-}" ]]; then
  _autotmux_want="${DOTFILES_TMUX_SESSION:-Gerrrt}"

  if ! tmux ls >/dev/null 2>&1; then
    # No server yet: start one so continuum restores before we decide what to join.
    tmux start-server
    # continuum's restore runs asynchronously on server start. Wait for it — but only
    # when a saved environment actually exists (so fresh machines pay no delay), and
    # cap the wait so a corrupt/empty save can never hang shell startup.
    if [[ -f "${XDG_DATA_HOME:-$HOME/.local/share}/tmux/resurrect/last" \
       || -f "$HOME/.tmux/resurrect/last" ]]; then
      _autotmux_i=0
      while (( _autotmux_i < 30 )) && ! tmux ls >/dev/null 2>&1; do
        sleep 0.1
        (( _autotmux_i += 1 ))
      done
      unset _autotmux_i
    fi
  fi

  # If continuum restored EXACTLY ONE session under a different name (the stale-save
  # case this fix targets), adopt it by renaming to the wanted name — so you land in
  # one session with the right name and its restored windows/panes. Skip the rename
  # when several sessions exist (don't hijack an arbitrary one) or when the sole
  # session is already the wanted one; a failed rename (e.g. a concurrent shell just
  # created the wanted name) is non-fatal — the create/attach below still resolves it.
  _autotmux_have=("${(@f)$(tmux ls -F '#{session_name}' 2>/dev/null)}")
  if (( ${#_autotmux_have} == 1 )) \
     && [[ -n "$_autotmux_have[1]" && "$_autotmux_have[1]" != "$_autotmux_want" ]]; then
    tmux rename-session -t "$_autotmux_have[1]" "$_autotmux_want" 2>/dev/null
  fi
  unset _autotmux_have

  # Race-safe finish: `new-session -A` ATTACHES to the wanted session if it exists now
  # (running, restored, or just renamed), else CREATES it. Deliberately not a bare
  # `attach-session` — since `exec` has already replaced this shell, attaching to a
  # session that vanished mid-race would kill the terminal; `-A` cannot.
  exec tmux new-session -A -s "$_autotmux_want"
fi
