# dotfiles-MacBook/zsh/zshrc  →  ~/.config/zsh/.zshrc
# ──────────────────────────────────────────────────────────────────────────────
# Interactive shell. Sources the Core modules (+ the macOS os layer + any local
# overrides) in the ONE correct order (matches the loop below and README):
#   tools → options → history → aliases → git → functions → fzf → bindings
#         → plugins → op → maint → update → os → local
#
# WHAT CHANGED (2026 refresh integration):
#   • options.zsh + history.zsh are NEW Core modules that now own setopts, the
#     completion system (compinit), and history config. They replace the inline
#     blocks that used to live in THIS file — that duplication was exactly the
#     drift the Core layer exists to kill, so the inline copies are gone.
#   • update.zsh (the `up` command + the once/day "updates available" nudge) and
#     maint.zsh (`maint-install` etc.) are sourced too — previously they were
#     symlinked into ~/.config/zsh but never loaded, so `up`/`maint-install`
#     didn't exist.
#
# Order is load-bearing: tools inits atuin (registers its widget) and fzf defines
# its zle widgets BEFORE plugins.zsh loads zsh-vi-mode, whose init fires the
# keybinding hook in bindings.zsh. options.zsh runs compinit BEFORE plugins.zsh
# (fzf-tab + carapace need it). update.zsh sits late so its nudge prints just
# above the prompt (incl. inside each new tmux pane).
#
# NOTE on history location: history.zsh sets HISTFILE to $ZDOTDIR/.zsh_history
# (was $XDG_STATE_HOME/zsh/history here). atuin holds your real searchable
# history regardless; if you want the old flat-file path, set HISTFILE in
# ~/.config/zsh/local.zsh (sourced last, so it wins).
# ──────────────────────────────────────────────────────────────────────────────

# ── XDG fallbacks ─────────────────────────────────────────────────────────────
# .zshenv normally exports these before we get here. Guard anyway so nothing
# downstream collapses to a bare path if .zshenv hasn't run (e.g. .zshrc sourced
# standalone).
: "${XDG_STATE_HOME:=$HOME/.local/state}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"

# ── Core modules + macOS layer + local overrides, in order ───────────────────
# (history + completion/compinit + setopts are owned by history.zsh/options.zsh.)
#
# Each module is byte-compiled to a .zwc on the side before sourcing: when a
# fresh $_f.zwc exists, `source $_f` loads the wordcode and skips re-parsing the
# script — meaningful across ~13 modules sourced on every shell. The compile only
# runs when the source is newer than its .zwc (or the .zwc is missing), so it's
# self-healing: edit a module (or `git pull`) and the next shell recompiles just
# that file; steady state is ~13 stats. zcompile is a builtin (no `>` redirection),
# so options.zsh's NO_CLOBBER doesn't apply, and it writes the .zwc atomically.
# The .zwc files land next to the symlinks in $ZSH_CFG (the runtime dir), so they
# never touch the repo. `2>/dev/null`: on a read-only $ZSH_CFG, compile silently
# no-ops and we just source the plain script.
ZSH_CFG="${ZDOTDIR:-$HOME/.config/zsh}"
for _m in tools options history aliases git functions fzf bindings plugins op maint update os local; do
  _f="$ZSH_CFG/$_m.zsh"
  [[ -r "$_f" ]] || continue
  # zcompile with NO trailing name args = script mode: it writes "$_f.zwc". (A
  # trailing function-name arg would switch it to function-digest mode, which
  # `source` can't use as wordcode — so keep it single-arg.)
  [[ -s "$_f.zwc" && ! "$_f" -nt "$_f.zwc" ]] || zcompile -R -- "$_f" 2>/dev/null
  source "$_f"
done
unset _m _f
