# dotfiles-MacBook/zsh/zprofile  →  ~/.config/zsh/.zprofile
# ──────────────────────────────────────────────────────────────────────────────
# Login-shell env (macOS). Terminal/iTerm/ghostty start login shells, so this
# runs once per session and is the right place for PATH-shaping env: Homebrew,
# language toolchains, and the 1Password SSH-agent socket.
# ──────────────────────────────────────────────────────────────────────────────
# Homebrew — Apple Silicon first, then Intel. `brew shellenv` output is static for a
# given prefix, so cache it and `source` the cache (one read) instead of forking brew
# on every login shell — which matters because the `exec tmux` below starts a login
# shell per pane. Regenerate only when the brew binary is newer than the cache. This
# is a zprofile-local cache (Core's _cache_eval isn't loaded yet at login-shell time).
# Falls back to a live eval when the cache dir isn't writable, so PATH is never lost.
() {
  local brew cache="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/brew-shellenv.zsh"
  for brew in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    [[ -x "$brew" ]] || continue
    if [[ ! -s "$cache" || "$brew" -nt "$cache" ]]; then
      mkdir -p "${cache:h}" 2>/dev/null && "$brew" shellenv >| "$cache" 2>/dev/null
    fi
    [[ -s "$cache" ]] && source "$cache" || eval "$("$brew" shellenv)"
    break
  done
}

# juliaup-managed Julia (if installed)
[[ -d "$HOME/.juliaup/bin" && ":$PATH:" != *":$HOME/.juliaup/bin:"* ]] && export PATH="$HOME/.juliaup/bin:$PATH"

# mise: trust THIS machine's dotfiles dir for project mise configs. This lives in the OS
# layer on purpose — the trusted path is machine-specific (the Core config.toml ships a
# portable default and must stay byte-identical to upstream so `git subtree pull` never
# conflicts). MISE_TRUSTED_CONFIG_PATHS is mise's env override (colon-separated); set here
# rather than edited into the vendored core/mise/config.toml.
export MISE_TRUSTED_CONFIG_PATHS="$HOME/dotfiles-MacBook${MISE_TRUSTED_CONFIG_PATHS:+:$MISE_TRUSTED_CONFIG_PATHS}"

# 1Password SSH agent (macOS). `ssh`/`git` use keys held in 1Password.
# Comment out if you don't use the 1Password agent.
export SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# 1Password SSH agent (macOS). `ssh`/`git` use keys held in 1Password. Guarded on
# the socket actually existing, so this self-disables (and ssh falls back to the
# default agent) when 1Password isn't installed/running — pointing SSH_AUTH_SOCK at
# a missing socket otherwise breaks ssh-add and every agent operation.
_op_ssh_sock="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
[[ -S "$_op_ssh_sock" ]] && export SSH_AUTH_SOCK="$_op_ssh_sock"
unset _op_ssh_sock
