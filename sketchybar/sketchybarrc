#!/usr/bin/env bash
# ================================================================================================
# sketchybar — programmable macOS menu bar (https://github.com/FelixKratz/SketchyBar)
# The macOS analog of this repo's hand-rolled tmux status bar (core/tmux): a plugin invoked per
# event, with one palette in colors.sh. Themed tokyonight-storm to match starship/tmux/lazygit.
# Icons use the already-installed CaskaydiaCove Nerd Font — no sketchybar-app-font dependency.
# ================================================================================================

CONFIG_DIR="$HOME/.config/sketchybar"
PLUGIN_DIR="$CONFIG_DIR/plugins"
# shellcheck source=/dev/null
source "$CONFIG_DIR/colors.sh"

FONT="CaskaydiaCove Nerd Font"

# ── Bar ─────────────────────────────────────────────────────────────────────────────────────
sketchybar --bar \
  height=40 \
  position=top \
  padding_left=8 \
  padding_right=8 \
  color="$BAR_COLOR" \
  corner_radius=9 \
  y_offset=4 \
  margin=8 \
  blur_radius=20

# ── Defaults shared by every item ───────────────────────────────────────────────────────────
# A short slide animation makes every label/icon swap (workspace switches, volume, battery)
# ease in instead of snapping — see plugins/aerospace.sh for the highlight transition.
sketchybar --default \
  updates=on \
  icon.font="$FONT:Bold:17.0" \
  icon.color="$FG" \
  label.font="$FONT:Semibold:17.0" \
  label.color="$FG" \
  background.color="$BG" \
  background.corner_radius=6 \
  background.height=15 \
  padding_left=5 \
  padding_right=5 \
  label.padding_left=4 \
  label.padding_right=4 \
  icon.padding_left=4 \
  icon.padding_right=4 \
  animation_curve=sin \
  animation_duration=15

# ── Left: brand anchor ──────────────────────────────────────────────────────────────────────
# Apple glyph; click reloads the bar (handy after editing this file).
sketchybar --add item logo left \
  --set logo \
  icon="" \
  icon.font="$FONT:Bold:18.0" \
  icon.color="$ACCENT" \
  label.drawing=off \
  background.drawing=off \
  click_script="sketchybar --reload"

# ── Left: AeroSpace workspaces ──────────────────────────────────────────────────────────────
# Custom event triggered by aerospace.toml's exec-on-workspace-change (FOCUSED_WORKSPACE=…).
# Clicking a number jumps to that workspace (aerospace workspace <id>).
sketchybar --add event aerospace_workspace_change

for sid in 1 2 3 4 5; do
  sketchybar --add item "space.$sid" left \
    --set "space.$sid" \
    label="$sid" \
    icon.drawing=off \
    background.drawing=off \
    click_script="aerospace workspace $sid" \
    script="$PLUGIN_DIR/aerospace.sh" \
    --subscribe "space.$sid" aerospace_workspace_change
done

# Group the workspace numbers inside a single rounded container.
sketchybar --add bracket spaces '/space\..*/' \
  --set spaces \
  background.color="$BG" \
  background.corner_radius=8 \
  background.height=26

# ── Left: front app name ────────────────────────────────────────────────────────────────────
sketchybar --add item front_app left \
  --set front_app \
  icon.drawing=off \
  label.color="$ACCENT" \
  label.font="$FONT:Bold:16.0" \
  script="$PLUGIN_DIR/front_app.sh" \
  --subscribe front_app front_app_switched

# ── Right: clock, battery, volume, cpu (right-to-left order) ─────────────────────────────────
# Magenta to match the tmux status-right clock pill (core/tmux/tmux.conf: 󰥔 %H:%M in @tn_magenta).
sketchybar --add item clock right \
  --set clock \
  icon="󰥔" \
  icon.color="$MAGENTA" \
  label.color="$MAGENTA" \
  update_freq=10 \
  script="$PLUGIN_DIR/clock.sh"

sketchybar --add item battery right \
  --set battery \
  update_freq=120 \
  script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery system_woke power_source_change

sketchybar --add item volume right \
  --set volume \
  script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change

# CPU load, colored green→yellow→red. Dependency-free (reads macOS `top`).
sketchybar --add item cpu right \
  --set cpu \
  icon="" \
  update_freq=5 \
  script="$PLUGIN_DIR/cpu.sh"

# ── Finalize ────────────────────────────────────────────────────────────────────────────────
sketchybar --update

# Paint the initial workspace highlight (sketchybar starts before any change event fires).
if command -v aerospace >/dev/null 2>&1; then
  sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE="$(aerospace list-workspaces --focused 2>/dev/null)"
fi
