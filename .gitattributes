# .gitattributes — line-ending policy + vendored-subtree marking for dotfiles-MacBook.
# ──────────────────────────────────────────────────────────────────────────────
# This repo is macOS-only, so the CRLF-shebang breakage that dotfiles-core guards
# against is unlikely here — but it VENDORS Core under core/ (a git subtree whose
# scripts assume LF), and a consistent LF policy is cheap insurance for the repo-owned
# shell entry points (zsh/zshenv, zsh/zprofile, zsh/zshrc — sourced, so a stray \r would
# corrupt values) and bootstrap.sh. .editorconfig sets eol=lf but only guides EDITORS;
# this governs what git writes on checkout/commit. Mirrors core/.gitattributes.
* text=auto eol=lf

# ── Executable + sourced shell — MUST stay LF or the shebang/sourcing breaks ───
*.sh         text eol=lf
*.zsh        text eol=lf
zsh/zshenv   text eol=lf
zsh/zprofile text eol=lf
zsh/zshrc    text eol=lf

# ── Config / data ─────────────────────────────────────────────────────────────
*.toml       text eol=lf
*.lock       text eol=lf
*.conf       text eol=lf
*.gitconfig  text eol=lf
*.md         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
Brewfile     text eol=lf
Makefile     text eol=lf

# ── Vendored Core subtree — authored upstream in dotfiles-core ─────────────────
# Mark it linguist-vendored so GitHub's language stats ignore it and PR diffs collapse
# it by default (it's not reviewed here — it's reviewed + gated in dotfiles-core, and
# `verify-core` asserts it's byte-for-byte upstream). Keeps this repo's diffs focused on
# the macOS overlay we actually own.
core/** linguist-vendored

# ── Binaries (defensive): never normalize, never diff as text ─────────────────
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.gz   binary
*.zip  binary
