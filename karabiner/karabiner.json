{
  "global": {
    "show_in_menu_bar": false
  },
  "profiles": [
    {
      "name": "Default",
      "selected": true,
      "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" },
      "complex_modifications": {
        "parameters": {
          "basic.simultaneous_threshold_milliseconds": 50,
          "basic.to_if_alone_timeout_milliseconds": 200,
          "basic.to_if_held_down_threshold_milliseconds": 200
        },
        "rules": [
          {
            "description": "Caps Lock → Control (held) / Escape (tapped)",
            "manipulators": [
              {
                "type": "basic",
                "from": {
                  "key_code": "caps_lock",
                  "modifiers": { "optional": ["any"] }
                },
                "to": [{ "key_code": "left_control", "lazy": true }],
                "to_if_alone": [{ "key_code": "escape" }]
              }
            ]
          },
          {
            "description": "Tab → Hyper layer (held) / Tab (tapped)",
            "manipulators": [
              {
                "type": "basic",
                "from": {
                  "key_code": "tab",
                  "modifiers": { "optional": ["any"] }
                },
                "to": [{ "set_variable": { "name": "hyper", "value": 1 } }],
                "to_after_key_up": [{ "set_variable": { "name": "hyper", "value": 0 } }],
                "to_if_alone": [{ "key_code": "tab" }]
              }
            ]
          },
          {
            "description": "Hyper layer — AeroSpace focus (hjkl) + fullscreen (f)",
            "manipulators": [
              {
                "type": "basic",
                "from": { "key_code": "h" },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace focus left" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "j" },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace focus down" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "k" },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace focus up" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "l" },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace focus right" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "f" },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace fullscreen" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              }
            ]
          },
          {
            "description": "Hyper layer — app launchers (t: terminal, b: browser)",
            "manipulators": [
              {
                "type": "basic",
                "from": { "key_code": "t" },
                "to": [{ "shell_command": "open -na Ghostty" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "b" },
                "to": [{ "shell_command": "open -a Safari" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              }
            ]
          },
          {
            "description": "Hyper layer — AeroSpace move (shift+hjkl), float toggle (space), new window (return)",
            "manipulators": [
              {
                "type": "basic",
                "from": { "key_code": "h", "modifiers": { "mandatory": ["shift"] } },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace move left" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "j", "modifiers": { "mandatory": ["shift"] } },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace move down" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "k", "modifiers": { "mandatory": ["shift"] } },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace move up" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "l", "modifiers": { "mandatory": ["shift"] } },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace move right" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "spacebar" },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace layout floating tiling" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "return_or_enter" },
                "to": [{ "shell_command": "open -na Ghostty" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              }
            ]
          },
          {
            "description": "Hyper layer — AeroSpace workspaces (1-5 focus, shift+1-5 move, n/p cycle)",
            "manipulators": [
              {
                "type": "basic",
                "from": { "key_code": "1" },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace workspace 1" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "2" },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace workspace 2" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "3" },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace workspace 3" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "4" },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace workspace 4" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "5" },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace workspace 5" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "1", "modifiers": { "mandatory": ["shift"] } },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace move-node-to-workspace --focus-follows-window 1" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "2", "modifiers": { "mandatory": ["shift"] } },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace move-node-to-workspace --focus-follows-window 2" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "3", "modifiers": { "mandatory": ["shift"] } },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace move-node-to-workspace --focus-follows-window 3" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "4", "modifiers": { "mandatory": ["shift"] } },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace move-node-to-workspace --focus-follows-window 4" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "5", "modifiers": { "mandatory": ["shift"] } },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace move-node-to-workspace --focus-follows-window 5" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "n" },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace workspace --wrap-around next" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              },
              {
                "type": "basic",
                "from": { "key_code": "p" },
                "to": [{ "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH aerospace workspace --wrap-around prev" }],
                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }]
              }
            ]
          }
        ]
      }
    }
  ]
}
