# dotfiles-MacBook/.gitignore — config + scripts only; never machine state/secrets.
.claude/
# machine-specific shell overrides (never synced; sourced last by .zshrc)
zsh/local.zsh
# Core is a vendored git-subtree under core/ and IS tracked — including the nvim
# lazy-lock.json, which is owned by dotfiles-core so every machine pins the same
# plugin set. Bump it upstream (make update-nvim-plugins) and re-sync, never here.
# noise / secrets
*.log
*.bak
.DS_Store
# editor swap/temp files (vim/neovim drop these next to the file being edited)
*.sw[a-p]
*~
.*.un~
.env
.env.*
!.env.example
# private SSH material — track ssh/config only, never keys
ssh/*
!ssh/config
